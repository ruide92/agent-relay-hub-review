{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-relay-hub.dev/contracts/v1/arp-message.schema.json",
  "title": "ARP Message Types and Conditional Constraints",
  "type": "object",
  "allOf": [
    { "$ref": "arp-envelope.schema.json" },

    { "if": { "properties": { "message_type": { "const": "command" } } }, "then": { "required": ["workflow_id", "job_id", "target"] } },
    { "if": { "properties": { "message_type": { "const": "result" } } }, "then": { "required": ["workflow_id", "job_id"] } },
    { "if": { "properties": { "message_type": { "const": "status" } } }, "then": { "required": ["workflow_id", "job_id"] } },
    { "if": { "properties": { "message_type": { "const": "review.finding" } } }, "then": { "required": ["workflow_id", "job_id"], "properties": { "payload": { "type": "object", "required": ["finding_id", "fingerprint", "severity_candidates"], "properties": { "finding_id": { "$ref": "common-defs.schema.json#/$defs/identifier" }, "fingerprint": { "type": "string", "minLength": 1 }, "severity_candidates": { "type": "array", "items": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] }, "minItems": 1 }, "unresolved_reason": { "type": "string" }, "evidence_refs": { "type": "array", "items": { "$ref": "common-defs.schema.json#/$defs/identifier" } } }, "additionalProperties": false } } } },
    { "if": { "properties": { "message_type": { "const": "evidence" } } }, "then": { "required": ["workflow_id", "artifacts"], "properties": { "payload": { "type": "object", "required": ["evidence_id"], "properties": { "evidence_id": { "$ref": "common-defs.schema.json#/$defs/identifier" }, "artifact_id": { "$ref": "common-defs.schema.json#/$defs/identifier" }, "verifier": { "type": "string", "minLength": 1 } }, "additionalProperties": false } } } },
    { "if": { "properties": { "message_type": { "const": "policy.decision" } } }, "then": { "required": ["workflow_id"], "properties": { "payload": { "type": "object", "required": ["policy_decision_id", "policy_version"], "properties": { "policy_decision_id": { "$ref": "common-defs.schema.json#/$defs/identifier" }, "policy_version": { "$ref": "common-defs.schema.json#/$defs/schema_version_v1" }, "decision": { "type": "string", "enum": ["allow", "deny", "degraded"] }, "authorization_tier_ceiling": { "$ref": "common-defs.schema.json#/$defs/authorization_tier" } }, "additionalProperties": false } } } },
    { "if": { "properties": { "message_type": { "const": "delivery.status" } } }, "then": { "required": ["workflow_id", "job_id", "delivery_attempt_id", "idempotency_key", "attempt"], "properties": { "payload": { "type": "object", "required": ["outbox_status"], "properties": { "outbox_status": { "type": "string", "enum": ["PREPARED", "DISPATCHING", "ACKNOWLEDGED", "VERIFIED", "RECONCILIATION_REQUIRED"] }, "external_state_known": { "type": "boolean" } }, "additionalProperties": false } } } },
    { "if": { "properties": { "message_type": { "const": "reconciliation.request" } } }, "then": { "required": ["workflow_id", "job_id", "delivery_attempt_id", "idempotency_key", "attempt"] } },
    { "if": { "properties": { "message_type": { "const": "reconciliation.result" } } }, "then": { "required": ["workflow_id", "job_id", "delivery_attempt_id", "idempotency_key", "attempt"] } },
    { "if": { "properties": { "message_type": { "const": "audit.event" } } }, "then": { "required": ["workflow_id"] } },
    { "if": { "properties": { "message_type": { "const": "cancellation" } } }, "then": { "required": ["workflow_id", "job_id", "target"] } },
    { "if": { "properties": { "message_type": { "const": "resume" } } }, "then": { "required": ["workflow_id", "job_id", "resume_token", "checkpoint"] } },

    { "if": { "properties": { "message_type": { "const": "heartbeat" } } }, "then": { "required": ["adapter_id", "session_id"] } },
    { "if": { "properties": { "message_type": { "const": "capability.negotiation" } } }, "then": { "required": ["adapter_id", "session_id"], "properties": { "payload": { "$ref": "adapter-capability.schema.json" } } } },
    { "if": { "properties": { "message_type": { "const": "lifecycle" } } }, "then": { "required": ["adapter_id", "session_id"], "properties": { "payload": { "$ref": "adapter-lifecycle-event.schema.json" } } } },
    { "if": { "properties": { "message_type": { "const": "health_check" } } }, "then": { "required": ["adapter_id", "session_id"], "properties": { "payload": { "$ref": "health-check.schema.json" } } } },
    { "if": { "properties": { "message_type": { "const": "capability_change" } } }, "then": { "required": ["adapter_id", "session_id"], "properties": { "payload": { "type": "object", "required": ["capability_set_before", "capability_set_after"], "properties": { "capability_set_before": { "type": "array", "items": { "$ref": "common-defs.schema.json#/$defs/capability_flag" }, "uniqueItems": true }, "capability_set_after": { "type": "array", "items": { "$ref": "common-defs.schema.json#/$defs/capability_flag" }, "uniqueItems": true } }, "additionalProperties": false } } } }
  ]
}