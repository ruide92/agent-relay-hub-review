{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-relay-hub.dev/contracts/v1/capability-token-claims.schema.json",
  "title": "Capability Token Claims Payload (Decoded View)",
  "type": "object",
  "required": [
    "iss", "aud", "sub", "iat", "nbf", "exp", "jti",
    "scope", "max_authorization_tier",
    "workflow_id", "job_id", "adapter_id", "session_id",
    "policy_bundle_hash", "policy_decision_id"
  ],
  "properties": {
    "iss": { "type": "string", "const": "arh:policy-engine" },
    "aud": { "type": "string", "enum": ["arh:core", "arh:adapter-host"] },
    "sub": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "iat": { "$ref": "common-defs.schema.json#/$defs/numeric_date", "description": "Issued At (RFC 7519 NumericDate, integer seconds since epoch)" },
    "nbf": { "$ref": "common-defs.schema.json#/$defs/numeric_date", "description": "Not Before (RFC 7519 NumericDate)" },
    "exp": { "$ref": "common-defs.schema.json#/$defs/numeric_date", "description": "Expiration Time (RFC 7519 NumericDate)" },
    "jti": { "$ref": "common-defs.schema.json#/$defs/jti_v4", "description": "UUIDv4 token identifier" },
    "scope": {
      "type": "array",
      "items": { "$ref": "common-defs.schema.json#/$defs/scope_registry" },
      "uniqueItems": true,
      "minItems": 1,
      "description": "Closed scope registry; unknown scopes MUST be rejected"
    },
    "max_authorization_tier": {
      "$ref": "common-defs.schema.json#/$defs/token_max_tier",
      "description": "Maximum tier grantable by token; A5 MUST NOT be granted"
    },
    "workflow_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "job_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "adapter_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "session_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "policy_bundle_hash": { "$ref": "common-defs.schema.json#/$defs/sha256_hex" },
    "policy_decision_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "nonce": { "type": "string", "minLength": 1 },
    "extensions": { "$ref": "common-defs.schema.json#/$defs/extensions_container" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "description": "Tier/scope co-occurrence: higher tiers must include required scopes",
      "if": { "properties": { "max_authorization_tier": { "const": "A3" } } },
      "then": { "properties": { "scope": { "contains": { "enum": ["git:commit", "git:push", "pr:create"] } } } }
    },
    {
      "if": { "properties": { "max_authorization_tier": { "const": "A4" } } },
      "then": { "properties": { "scope": { "contains": { "const": "deploy:staging" } } } }
    }
  ]
}