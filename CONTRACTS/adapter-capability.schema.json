{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-relay-hub.dev/contracts/v1/adapter-capability.schema.json",
  "title": "Adapter Capability Report",
  "type": "object",
  "required": ["schema_version", "adapter_id", "session_id", "supported_protocol_versions", "capability_set"],
  "properties": {
    "schema_version": { "$ref": "common-defs.schema.json#/$defs/schema_version_v1" },
    "adapter_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "session_id": { "$ref": "common-defs.schema.json#/$defs/identifier" },
    "supported_protocol_versions": {
      "type": "array",
      "items": { "$ref": "common-defs.schema.json#/$defs/protocol_version_v1" },
      "minItems": 1
    },
    "capability_set": {
      "type": "array",
      "items": { "$ref": "common-defs.schema.json#/$defs/capability_flag" },
      "uniqueItems": true,
      "description": "Closed capability flag registry; delivery_semantics and max_payload_size are separate top-level properties, NOT capability flags"
    },
    "delivery_semantics": { "$ref": "common-defs.schema.json#/$defs/delivery_semantics" },
    "max_payload_size": { "type": "integer", "minimum": 0 },
    "extensions": { "$ref": "common-defs.schema.json#/$defs/extensions_container" }
  },
  "additionalProperties": false,
  "not": {
    "properties": {
      "capability_set": { "contains": { "const": "supports_exactly_once_claim" } }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "capability_set": { "contains": { "const": "supports_reconciliation" } } } },
      "then": { "properties": { "delivery_semantics": { "const": "at_least_once_attempts" } } },
      "description": "If supports_reconciliation is reported, delivery_semantics should be at_least_once_attempts"
    }
  ]
}